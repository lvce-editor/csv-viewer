{
  "name": "builtin.csv-viewer-monorepo",
  "version": "0.0.0-dev",
  "description": "CSV viewer extension",
  "type": "module",
  "scripts": {
    "build": "node packages/build/src/build-static.js",
    "dev": "node packages/server/src/dev.js",
    "e2e": "cd packages/e2e && npm run e2e",
    "e2e:headless": "cd packages/e2e && npm run e2e:headless",
    "postinstall": "lerna bootstrap --ci",
    "lint": "eslint . && prettier --check .",
    "test": "lerna run test",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "type-check": "tsc -b"
  },
  "author": {
    "name": "Le Vivilet",
    "email": "levivilet@pm.me"
  },
  "license": "MIT",
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.2",
    "@lvce-editor/eslint-config": "^17.0.3",
    "@types/node": "^22.7.7",
    "eslint": "^10.7.0",
    "jest": "^29.7.0",
    "lerna": "^8.2.2",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.0"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 130
  }
}
