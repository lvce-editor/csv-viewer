{
  "name": "csv-viewer-integration",
  "version": "0.0.0-dev",
  "description": "Integration tests for the CSV viewer",
  "main": "index.js",
  "scripts": {
    "test": "node --unhandled-rejections=warn --experimental-vm-modules ../../node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ../../node_modules/jest/bin/jest.js --watch"
  },
  "type": "module",
  "author": {
    "name": "Le Vivilet",
    "email": "levivilet@pm.me"
  },
  "license": "MIT",
  "jest": {
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "diagnostics": false
        }
      ]
    }
  }
}
